{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Riven",
  "scopeName": "source.riven",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#constants" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.number-sign.riven", "match": "#.*$" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.riven",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.riven", "match": "\\\\." },
            { "name": "meta.interpolation.riven", "begin": "#\\{", "end": "\\}", "patterns": [{ "include": "$self" }] }
          ]
        },
        {
          "name": "string.quoted.single.riven",
          "begin": "'",
          "end": "'",
          "patterns": [{ "name": "constant.character.escape.riven", "match": "\\\\." }]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.riven", "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b" },
        { "name": "constant.numeric.hex.riven", "match": "\\b0x[0-9a-fA-F_]+\\b" },
        { "name": "constant.numeric.integer.riven", "match": "\\b[0-9][0-9_]*\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.riven",
          "match": "\\b(if|else|elsif|end|match|case|for|in|while|loop|do|break|continue|return|rescue|raise|async|await)\\b"
        },
        {
          "name": "keyword.declaration.riven",
          "match": "\\b(let|mut|def|fn|class|struct|enum|trait|impl|module|pub|actor|newtype)\\b"
        },
        {
          "name": "keyword.operator.word.riven",
          "match": "\\b(and|or|not|as|self|Self)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.riven", "match": "\\b(true|false|None|Some|Ok|Err)\\b" }
      ]
    },
    "types": {
      "patterns": [
        { "name": "storage.type.riven", "match": "\\b(Int|Float|Bool|String|Char|Vec|Hash|Set|Option|Result|Box|Rc|Arc)\\b" },
        { "name": "entity.name.type.riven", "match": "\\b[A-Z][A-Za-z0-9_]*\\b" }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.definition.riven",
          "match": "\\b(def|fn)\\s+([a-z_][A-Za-z0-9_]*[!?]?)",
          "captures": {
            "1": { "name": "keyword.declaration.riven" },
            "2": { "name": "entity.name.function.riven" }
          }
        },
        {
          "match": "\\b([a-z_][A-Za-z0-9_]*[!?]?)\\s*\\(",
          "captures": { "1": { "name": "entity.name.function.call.riven" } }
        }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.riven", "match": "(==|!=|<=|>=|<|>|\\+|-|\\*|/|%|=|&&|\\|\\||!|\\?\\.|::|->|=>)" }
      ]
    }
  }
}
