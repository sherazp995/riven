# Mini sample: Trimmed version of the sample program to test

enum Priority
  Low
  Medium
  High
  Critical
end

impl Priority
  pub def weight -> Int
    match self
      Priority.Low      -> 1
      Priority.Medium   -> 2
      Priority.High     -> 3
      Priority.Critical -> 4
    end
  end
end

enum TaskError
  MissingField(name: String)
end

class Task
  id: Int
  title: String
  priority: Priority

  def init(@id: Int, @title: String, @priority: Priority)
  end

  pub def id -> Int { self.id }
end

def parse_priority(input: &str) -> Result[Priority, TaskError]
  Ok(Priority.High)
end

def create_task_from_input(
  title: &str,
  priority_str: &str
) -> Result[Int, TaskError]
  if title == ""
    return Err(TaskError.MissingField(name: String.from("title")))
  end
  let id = 1
  Ok(id)
end

def main
  puts "Creating tasks..."

  let r1 = create_task_from_input("Design model", "critical")
  match r1
    Ok(id)  -> puts "  Created task"
    Err(e)  -> puts "  Failed"
  end

  let r2 = create_task_from_input("", "high")
  match r2
    Ok(id)  -> puts "  Created task"
    Err(e)  -> puts "  Failed"
  end

  puts "Done"
end
