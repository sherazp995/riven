# ============================================================================
# Task Manager — Riven Language Showcase
# ============================================================================

# --- Type Definitions ---

enum Priority
  Low
  Medium
  High
  Critical
end

impl Priority
  pub def weight -> Int
    match self
      Priority.Low      -> 1
      Priority.Medium   -> 2
      Priority.High     -> 3
      Priority.Critical -> 4
    end
  end
end

impl Displayable for Priority
  def to_display -> String
    match self
      Priority.Low      -> String.from("LOW")
      Priority.Medium   -> String.from("MEDIUM")
      Priority.High     -> String.from("HIGH")
      Priority.Critical -> String.from("CRITICAL")
    end
  end
end

enum Status
  Pending
  InProgress(assignee: String)
  Completed(completed_at: String)
  Cancelled(reason: String)
end

impl Displayable for Status
  def to_display -> String
    match self
      Status.Pending              -> String.from("Pending")
      Status.InProgress(who)      -> "In Progress (#{who})"
      Status.Completed(date)      -> "Completed on #{date}"
      Status.Cancelled(reason)    -> "Cancelled: #{reason}"
    end
  end
end

enum TaskError
  InvalidPriority(value: String)
  MissingField(name: String)
  ParseFailed(message: String)
  NotFound(id: USize)
end

impl Error for TaskError
  def message -> String
    match self
      TaskError.InvalidPriority(v)  -> "Invalid priority: '#{v}'"
      TaskError.MissingField(name)  -> "Missing required field: #{name}"
      TaskError.ParseFailed(msg)    -> "Parse error: #{msg}"
      TaskError.NotFound(id)        -> "Task ##{id} not found"
    end
  end
end

# --- Traits ---

trait Serializable
  def serialize -> String
  def self.deserialize(data: &str) -> Result[Self, TaskError]
end

trait Summarizable
  def summary -> String
  def is_actionable -> Bool
end

# --- Classes ---

class Task
  id: USize
  title: String
  description: String
  status: Status
  priority: Priority

  def init(@id: USize, @title: String, @description: String, @priority: Priority)
    self.status = Status.Pending
  end

  pub def id -> USize { self.id }

  pub def title_ref -> &String { &self.title }

  pub def priority_ref -> &Priority { &self.priority }

  pub def is_done -> Bool
    match &self.status
      Status.Completed(_) -> true
      Status.Cancelled(_) -> true
      _ -> false
    end
  end

  pub def mut assign(assignee: String)
    self.status = Status.InProgress(assignee: assignee)
  end

  pub def mut complete(date: String)
    self.status = Status.Completed(completed_at: date)
  end

  pub def mut cancel(reason: String)
    self.status = Status.Cancelled(reason: reason)
  end
end

impl Displayable for Task
  def to_display -> String
    "[##{self.id}] #{self.title} | #{self.priority.to_display} | #{self.status.to_display}"
  end
end

impl Summarizable for Task
  def summary -> String
    "#{self.title} (#{self.priority.to_display})"
  end

  def is_actionable -> Bool
    match &self.status
      Status.Pending          -> true
      Status.InProgress(_)    -> true
      _                       -> false
    end
  end
end

impl Serializable for Task
  def serialize -> String
    "#{self.id}|#{self.title}|#{self.description}|#{self.priority.to_display}"
  end

  def self.deserialize(data: &str) -> Result[Task, TaskError]
    let parts: Vec[&str] = data.split("|").to_vec
    if parts.len < 4
      return Err(TaskError.ParseFailed(
        message: String.from("expected 4 fields, got #{parts.len}")
      ))
    end

    let id = parts[0].parse_uint
      .map_err { |_| TaskError.ParseFailed(message: String.from("invalid id")) }?

    let priority = parse_priority(parts[3])?

    Ok(Task.new(
      id,
      String.from(parts[1]),
      String.from(parts[2]),
      priority
    ))
  end
end

class TimedTask < Task
  deadline: String
  estimated_hours: Float

  def init(
    id: USize,
    title: String,
    description: String,
    priority: Priority,
    @deadline: String,
    @estimated_hours: Float
  )
    super(id, title, description, priority)
  end

  pub def is_overdue(current_date: &str) -> Bool
    # Simple string comparison — a real app would use proper date types
    !self.is_done && current_date > &self.deadline
  end

  pub def deadline_ref -> &String { &self.deadline }
end

impl Displayable for TimedTask
  def to_display -> String
    let base = "[##{self.id}] #{self.title} | #{self.priority.to_display}"
    let time = "Due: #{self.deadline} (#{self.estimated_hours}h est.)"
    "#{base} | #{time} | #{self.status.to_display}"
  end
end

# --- Generic Repository ---

class Repository[T: Displayable]
  items: Vec[T]
  next_id: USize

  def init
    self.items = Vec.new
    self.next_id = 1
  end

  pub def mut add(item: T) -> USize
    # item is moved into the Vec — caller gives up ownership
    let id = self.next_id
    self.items.push(item)
    self.next_id += 1
    id
  end

  pub def count -> USize
    self.items.len
  end

  pub def get(index: USize) -> Option[&T]
    self.items.get(index)
  end

  pub def get_mut(index: USize) -> Option[&mut T]
    self.items.get_mut(index)
  end

  pub def all -> &Vec[T]
    &self.items
  end

  # Takes a predicate block, returns borrowed references to matching items
  pub def where_matching(&block: Block(&T) -> Bool) -> Vec[&T]
    self.items.iter
      .filter { |item| yield item }
      .to_vec
  end

  # Consumes the repository, returns only items that pass the predicate
  pub def consume into_filtered(predicate: Fn(&T) -> Bool) -> Vec[T]
    self.items.into_iter
      .filter { |item| predicate.(&item) }
      .to_vec
  end

  pub def display_all
    if self.items.is_empty
      puts "  (empty)"
      return
    end
    self.items.each { |item| puts "  #{item.to_display}" }
  end
end

# --- TaskList (domain-specific wrapper) ---

class TaskList
  repo: Repository[Task]

  def init
    self.repo = Repository.new
  end

  pub def mut add_task(title: String, desc: String, priority: Priority) -> USize
    let task = Task.new(self.repo.count, title, desc, priority)
    self.repo.add(task)
  end

  pub def find_by_id(id: USize) -> Option[&Task]
    self.repo.all.iter.find { |t| t.id == id }
  end

  pub def mut update_status(id: USize, status: Status) -> Result[(), TaskError]
    let task = self.repo.all.iter
      .position { |t| t.id == id }
      .ok_or(TaskError.NotFound(id: id))?

    match self.repo.get_mut(task)
      Some(t) -> match status
        Status.InProgress(ref assignee) -> t.assign(assignee.clone)
        Status.Completed(ref date)      -> t.complete(date.clone)
        Status.Cancelled(ref reason)    -> t.cancel(reason.clone)
        Status.Pending                  -> t.status = Status.Pending
      end
      None -> return Err(TaskError.NotFound(id: id))
    end

    Ok(())
  end

  pub def high_priority_tasks -> Vec[&Task]
    self.repo.where_matching { |t| t.priority_ref.weight >= 3 }
  end

  pub def actionable_tasks -> Vec[&Task]
    self.repo.where_matching { |t| t.is_actionable }
  end

  pub def display
    puts "--- All Tasks ---"
    self.repo.display_all
  end

  # Consumes the TaskList, returns only completed tasks
  pub def consume into_completed -> Vec[Task]
    self.repo.into_filtered({ |t| t.is_done })
  end
end

# --- Helper Functions ---

def parse_priority(input: &str) -> Result[Priority, TaskError]
  match input.trim.to_lower.as_str
    "low"      -> Ok(Priority.Low)
    "medium"   -> Ok(Priority.Medium)
    "high"     -> Ok(Priority.High)
    "critical" -> Ok(Priority.Critical)
    other      -> Err(TaskError.InvalidPriority(value: String.from(other)))
  end
end

# Accepts borrowed tasks, returns a formatted report — no ownership taken
def generate_report(tasks: &Vec[&Task]) -> String
  let mut report = String.from("=== Task Report ===\n")

  let (done, active): (Vec[&&Task], Vec[&&Task]) = tasks.iter
    .partition { |t| t.is_done }

  report.push_str("Active: #{active.len}\n")
  report.push_str("Completed: #{done.len}\n\n")

  for task in active
    report.push_str("  [ ] #{task.summary}\n")
  end
  for task in done
    report.push_str("  [x] #{task.summary}\n")
  end

  report
end

# Demonstrates generic function with trait bounds
def print_items[T: Displayable + Summarizable](items: &Vec[T], label: &str)
  puts "--- #{label} ---"
  items.each do |item|
    if item.is_actionable
      puts "  * #{item.summary}"
    else
      puts "    #{item.summary} (done)"
    end
  end
end

# Demonstrates closure stored in a variable
def apply_filter[T](items: &Vec[T], predicate: &Fn(&T) -> Bool) -> Vec[&T]
  items.iter.filter { |item| predicate.(item) }.to_vec
end

# Demonstrates error propagation with ?
def create_task_from_input(
  list: &mut TaskList,
  title: &str,
  desc: &str,
  priority_str: &str
) -> Result[USize, TaskError]
  if title.is_empty
    return Err(TaskError.MissingField(name: String.from("title")))
  end
  if desc.is_empty
    return Err(TaskError.MissingField(name: String.from("description")))
  end

  let priority = parse_priority(priority_str)?  # ? propagates TaskError
  let id = list.add_task(
    String.from(title),
    String.from(desc),
    priority
  )
  Ok(id)
end

# --- Main ---

def main
  let mut list = TaskList.new

  # ── Create tasks via helper (demonstrates ? operator) ──
  puts "Creating tasks..."

  let results = vec![
    create_task_from_input(&mut list, "Design ownership model", "Define borrow rules", "critical"),
    create_task_from_input(&mut list, "Write parser",           "Implement lexer+parser", "high"),
    create_task_from_input(&mut list, "Add syntax highlighting", "Editor plugin",         "medium"),
    create_task_from_input(&mut list, "Update README",           "Document new features",  "low"),
    create_task_from_input(&mut list, "Fix borrow checker bug",  "Edge case in closures",  "critical"),
    create_task_from_input(&mut list, "",                         "Missing title",          "high"),
  ]

  # ── Report creation results (pattern matching) ──
  for (i, result) in results.into_iter.enumerate
    match result
      Ok(id)  -> puts "  Created task ##{id}"
      Err(e)  -> puts "  Failed: #{e.message}"
    end
  end

  puts ""

  # ── Display all tasks ──
  list.display

  puts ""

  # ── Update statuses (demonstrates &mut self and pattern matching) ──
  puts "Updating statuses..."
  list.update_status(0, Status.InProgress(assignee: String.from("Alaric")))
    .unwrap_or_else { |e| eputs "  #{e.message}" }

  list.update_status(0, Status.Completed(completed_at: String.from("2026-04-11")))
    .unwrap_or_else { |e| eputs "  #{e.message}" }

  list.update_status(1, Status.InProgress(assignee: String.from("Dana")))
    .unwrap_or_else { |e| eputs "  #{e.message}" }

  # Try updating a non-existent task (demonstrates error handling)
  match list.update_status(99, Status.Pending)
    Ok(()) -> puts "  Updated"
    Err(TaskError.NotFound(id)) -> puts "  Task ##{id} doesn't exist (expected)"
    Err(e) -> puts "  Unexpected: #{e.message}"
  end

  puts ""

  # ── Query with closures (demonstrates blocks and stored closures) ──
  puts "--- High Priority ---"
  let urgent = list.high_priority_tasks
  for task in &urgent
    puts "  #{task.to_display}"
  end

  puts ""

  # Closure stored in a variable and passed to a function
  let is_pending = { |t: &&Task|
    match &t.status
      Status.Pending -> true
      _ -> false
    end
  }
  let pending = apply_filter(list.repo.all, &is_pending)
  puts "--- Pending Tasks (#{pending.len}) ---"
  pending.each { |t| puts "  #{t.to_display}" }

  puts ""

  # ── Find by ID (demonstrates Option) ──
  let task_name = list.find_by_id(1)
    .map { |t| t.title_ref.clone }
    .unwrap_or(String.from("Unknown"))
  puts "Task #1: #{task_name}"

  # Safe navigation chain
  let deadline_info = list.find_by_id(0)
    ?.title_ref
    .map { |title| "Found: #{title}" }
    .unwrap_or(String.from("Not found"))
  puts deadline_info

  puts ""

  # ── Generate report (demonstrates borrowing — list is NOT consumed) ──
  let all_refs: Vec[&Task] = list.repo.all.iter.to_vec
  let report = generate_report(&all_refs)
  puts report

  # ── Print with generic function ──
  print_items(list.repo.all, "Final Overview")

  puts ""

  # ── Consume the list (demonstrates ownership transfer) ──
  puts "Archiving completed tasks..."
  let completed = list.into_completed
  # `list` is now consumed — cannot be used

  puts "Archived #{completed.len} completed tasks:"
  completed.each { |t| puts "  #{t.to_display}" }

  # This would be a compile error:
  # list.display  # ERROR: `list` was consumed by `into_completed`
end
