# Class with methods and enum
enum Priority
  Low
  High
end

impl Priority
  pub def weight -> Int
    match self
      Priority.Low  -> 1
      Priority.High -> 3
    end
  end
end

class Task
  id: Int
  priority: Priority

  def init(@id: Int, @priority: Priority)
  end

  pub def is_high -> Bool
    match &self.priority
      Priority.High -> true
      _ -> false
    end
  end
end

def main
  puts "Starting..."
  let t = Task.new(1, Priority.High)
  puts "Created task"
  if t.is_high
    puts "high priority"
  else
    puts "low priority"
  end
end
