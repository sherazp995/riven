enum Priority
  Low
  Medium
  High
end

impl Priority
  pub def label -> String
    match self
      Priority.Low    -> String.from("low")
      Priority.Medium -> String.from("medium")
      Priority.High   -> String.from("high")
    end
  end
end

def main
  puts Priority.Low.label
  puts Priority.Medium.label
  puts Priority.High.label
end
