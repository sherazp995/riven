trait A
  def a_msg -> String
end

trait B: A
  def b_msg -> String
end

class Thing
  name: String

  def init(@name: String)
  end
end

impl A for Thing
  def a_msg -> String
    "A: #{self.name}"
  end
end

impl B for Thing
  def b_msg -> String
    "B: #{self.name}"
  end
end

def main
  let t = Thing.new(String.from("x"))
  puts "#{t.a_msg}"
  puts "#{t.b_msg}"
end
