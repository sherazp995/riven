trait Displayable
  def to_display -> String
end

trait Tagged
  def tag -> String
end

class Item
  name: String

  def init(@name: String)
  end
end

impl Displayable for Item
  def to_display -> String
    self.name.clone
  end
end

impl Tagged for Item
  def tag -> String
    "T:#{self.name}"
  end
end

def show[T: Displayable + Tagged](x: &T)
  puts "#{x.to_display}"
  puts "#{x.tag}"
end

def main
  let i = Item.new(String.from("one"))
  show(&i)
end
