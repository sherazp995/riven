trait Displayable
  def to_display -> String
end

class Tag
  label: String

  def init(@label: String)
  end
end

impl Displayable for Tag
  def to_display -> String
    self.label.clone
  end
end

def print_it(x: &impl Displayable)
  puts "#{x.to_display}"
end

def main
  let t = Tag.new(String.from("hi"))
  print_it(&t)
end
