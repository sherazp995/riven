enum Light
  Red
  Yellow
  Green
end

impl Light
  pub def describe -> String
    match self
      Light.Red    -> String.from("stop")
      Light.Yellow -> String.from("slow")
      Light.Green  -> String.from("go")
    end
  end
end

def main
  puts "#{Light.Red.describe}"
  puts "#{Light.Yellow.describe}"
  puts "#{Light.Green.describe}"
end
