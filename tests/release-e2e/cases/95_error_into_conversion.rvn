enum SrcErr
  Bad
end

enum DstErr
  Wrapped(msg: String)
end

impl Into[DstErr] for SrcErr
  def consume into -> DstErr
    DstErr.Wrapped(msg: String.from("src was bad"))
  end
end

def low -> Result[Int, SrcErr]
  Err(SrcErr.Bad)
end

def high -> Result[Int, DstErr]
  let v = low()?
  Ok(v)
end

def main
  match high()
    Ok(v)  -> puts "ok #{v}"
    Err(DstErr.Wrapped(m)) -> puts "err #{m}"
  end
end
