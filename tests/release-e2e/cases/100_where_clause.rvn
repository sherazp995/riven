trait Displayable
  def to_display -> String
end

impl Displayable for Int
  def to_display -> String
    "#{self}"
  end
end

def merge[A, B](x: A, y: B) -> String
  where A: Displayable,
        B: Displayable
  "#{x.to_display}+#{y.to_display}"
end

def main
  let s = merge(1, 2)
  puts "#{s}"
end
