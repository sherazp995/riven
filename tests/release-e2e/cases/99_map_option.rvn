def find(n: Int) -> Option[Int]
  if n > 0
    Some(n)
  else
    None
  end
end

def main
  let a = find(5).map { |n| n * 2 }
  let b = find(-1).map { |n| n * 2 }
  match a
    Some(v) -> puts "some #{v}"
    None    -> puts "none"
  end
  match b
    Some(v) -> puts "some #{v}"
    None    -> puts "none"
  end
end
