trait Greetable
  def name -> String
  def greet -> String
    "Hello, #{self.name}!"
  end
end

class Person
  pname: String

  def init(@pname: String)
  end
end

impl Greetable for Person
  def name -> String
    self.pname.clone
  end
end

def main
  let p = Person.new(String.from("Alice"))
  puts p.greet
end
